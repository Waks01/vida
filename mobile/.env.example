# Vida Mobile Environment Configuration
# Copy this to .env and update values, or run update-api-url.bat

# Backend API URL
# - For Android Emulator: http://10.0.2.2:8000
# - For iOS Simulator: http://localhost:8000
# - For Physical Device: http://YOUR_LOCAL_IP:8000 (run update-api-url.bat)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: Analytics & Third-party Services
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# EXPO_PUBLIC_AMPLITUDE_KEY=
